    {
      "id": 7,
      "title": "LTE Signal Quality",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "cellsentry-prometheus" },
      "targets": [
        {
          "expr": "cellsentry_lte_rsrp_dbm",
          "legendFormat": "RSRP",
          "refId": "A"
        },
        {
          "expr": "cellsentry_lte_rsrq_db",
          "legendFormat": "RSRQ",
          "refId": "B"
        },
        {
          "expr": "cellsentry_lte_snr_db",
          "legendFormat": "SNR",
          "refId": "C"
        },
        {
          "expr": "cellsentry_lte_rssi_dbm",
          "legendFormat": "RSSI",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull", "min", "max"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dB",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RSRP" },
            "properties": [
              { "id": "unit", "value": "dBm" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",    "value": null },
                    { "color": "orange", "value": -110 },
                    { "color": "yellow", "value": -100 },
                    { "color": "green",  "value": -85 }
                  ]
                }
              },
              { "id": "custom.thresholdsStyle", "value": { "mode": "line" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RSSI" },
            "properties": [
              { "id": "unit", "value": "dBm" }
            ]
          }
        ]
      }
    },
